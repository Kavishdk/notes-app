{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "isolatedModules": false,
    "jsx": "react-jsx"
  },
  "include": ["server.ts", "backend/**/*.ts"]
}
